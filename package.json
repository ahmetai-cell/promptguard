{
  "name": "promptguard",
  "version": "0.1.0",
  "description": "Browser-layer prompt injection detection for LLM APIs",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:prod": "node scripts/build.js --prod",
    "build:watch": "node scripts/build.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run build && npm test",
    "package": "npm run build:prod && node scripts/package.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "esbuild": "^0.28.0",
    "vitest": "^1.6.0"
  }
}
